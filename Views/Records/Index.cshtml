@model IReadOnlyList<ExperimentRecord>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Records";
    string currentSort = (string?)ViewBag.SortBy ?? "UpdatedAtUtc";
    bool currentDescending = (bool?)ViewBag.Descending ?? true;
    string nextDirection(string sortBy) => currentSort == sortBy && !currentDescending ? "true" : "false";
    var userOptions = (IEnumerable<SelectListItem>?)ViewBag.UserOptions ?? Enumerable.Empty<SelectListItem>();
    string usernameFor(ExperimentRecord record) => record.CreatedByUser?.UserName
        ?? record.CreatedByUser?.Email
        ?? record.CreatedByUser?.DisplayName
        ?? record.CreatedByUserId;
}

<section class="page-header split">
    <div>
        <p class="eyebrow">Experiment Records</p>
        <h1>Records</h1>
    </div>
    <a class="button primary" asp-action="Create">New record</a>
</section>

<form method="get" class="toolbar">
    <input type="search" name="q" value="@ViewBag.Query" placeholder="Search title, code, or project" />
    <select name="status">
        <option value="">All statuses</option>
        @foreach (RecordStatus status in Enum.GetValues(typeof(RecordStatus)))
        {
            <option value="@status" selected="@(Equals(ViewBag.Status, status) ? "selected" : null)">@status</option>
        }
    </select>
    <select name="userId">
        <option value="">All users</option>
        @foreach (var user in userOptions)
        {
            <option value="@user.Value" selected="@(Equals(ViewBag.UserId, user.Value) ? "selected" : null)">@user.Text</option>
        }
    </select>
    <button type="submit" class="button secondary">Filter</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="ExperimentCode" asp-route-descending="@nextDirection("ExperimentCode")">Code</a></th>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="Title" asp-route-descending="@nextDirection("Title")">Title</a></th>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="ConductedOn" asp-route-descending="@nextDirection("ConductedOn")">Date</a></th>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="ProjectName" asp-route-descending="@nextDirection("ProjectName")">Project</a></th>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="UserName" asp-route-descending="@nextDirection("UserName")">User</a></th>
            <th><a asp-action="Index" asp-route-q="@ViewBag.Query" asp-route-status="@ViewBag.Status" asp-route-userId="@ViewBag.UserId" asp-route-sortBy="Status" asp-route-descending="@nextDirection("Status")">Status</a></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ExperimentCode</td>
            <td>@item.Title</td>
            <td>@item.ConductedOn</td>
            <td>@item.ProjectName</td>
            <td>@usernameFor(item)</td>
            <td><span class="status @item.Status.ToString().ToLowerInvariant()">@item.Status</span></td>
            <td>
                <div class="button-group">
                    <a asp-action="Details" asp-route-id="@item.Id">Open</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Researcher"))
                    {
                        <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this record?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="button ghost danger">Delete</button>
                        </form>
                    }
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
