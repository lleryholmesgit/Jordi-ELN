@model ExperimentRecord
@{
    ViewData["Title"] = "Record details";
}

<section class="page-header split">
    <div>
        <p class="eyebrow">Experiment Record</p>
        <h1>@Model.Title</h1>
        <p>@Model.ExperimentCode · @Model.ConductedOn · <span class="status @Model.Status.ToString().ToLowerInvariant()">@Model.Status</span></p>
    </div>
    <div class="button-group">
        <a class="button ghost" asp-action="ExportTrail" asp-route-id="@Model.Id">Export trail.txt</a>
        @if ((User.IsInRole("Admin") || User.IsInRole("Researcher")) && (Model.Status == RecordStatus.Draft || Model.Status == RecordStatus.Rejected))
        {
            <a class="button secondary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
            <form asp-action="Delete" method="post" class="inline-form" onsubmit="return confirm('Delete this record?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="button ghost danger">Delete</button>
            </form>
        }
    </div>
</section>

@if (TempData["RecordError"] is string recordError)
{
    <section class="panel form-panel validation">@recordError</section>
}

<section class="details-grid">
    <article class="panel">
        <h2>Overview</h2>
        <dl class="definition-list">
            <div><dt>Project</dt><dd>@Model.ProjectName</dd></div>
            <div><dt>Technician</dt><dd>@Model.PrincipalInvestigator</dd></div>
            <div><dt>Template</dt><dd>@Model.Template?.Name</dd></div>
            <div><dt>Review comment</dt><dd>@Model.ReviewComment</dd></div>
            <div><dt>E-signature</dt><dd>@Model.SignatureStatement</dd></div>
        </dl>
        <h3>Notebook</h3>
        <div class="rich-content notebook-rendered-content">@Html.Raw(Model.RichTextContent)</div>
        <h3>Flowchart</h3>
        <div class="panel form-panel flowchart-readonly" data-flowchart-viewer data-flowchart-source='@Model.FlowchartJson'>
            <div class="flowchart-canvas" data-flowchart-canvas></div>
            <p class="small-note" data-flowchart-empty hidden>No flowchart nodes have been saved for this record yet.</p>
        </div>
    </article>

    <article class="panel">
        <h2>Review history</h2>
        <ul class="entity-list">
            @foreach (var item in Model.ReviewHistory.OrderByDescending(x => x.CreatedAtUtc))
            {
                <li>
                    <span>@item.Action</span>
                    <span>@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                    <strong>@item.Comment</strong>
                </li>
            }
        </ul>
    </article>
</section>

@if ((User.IsInRole("Admin") || User.IsInRole("Researcher")) && (Model.Status == RecordStatus.Draft || Model.Status == RecordStatus.Rejected))
{
    <form asp-action="Submit" method="post" class="inline-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="button primary">Submit for review</button>
    </form>
}

@if ((User.IsInRole("Admin") || User.IsInRole("Reviewer")) && Model.Status == RecordStatus.Submitted)
{
    <section class="review-actions">
        <form asp-action="Approve" method="post" class="review-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <label>Approval comment</label>
            <textarea name="comment" rows="3"></textarea>
            <button type="submit" class="button primary">Approve</button>
        </form>
        <form asp-action="Reject" method="post" class="review-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <label>Rejection comment</label>
            <textarea name="comment" rows="3"></textarea>
            <button type="submit" class="button ghost danger">Reject</button>
        </form>
    </section>
}
