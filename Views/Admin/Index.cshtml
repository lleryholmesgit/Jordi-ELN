@model AdminIndexViewModel
@{
    ViewData["Title"] = "Admin";
    bool isPhoneClient = ClientDeviceDetector.IsPhoneClient(Context.Request);
}

<section class="page-header">
    <p class="eyebrow">Administration</p>
    <h1>Admin overview</h1>
    <p>Review users, assign roles, and monitor shared template availability.</p>
</section>

@if (TempData["AdminMessage"] is string adminMessage)
{
    <section class="panel form-panel">@adminMessage</section>
}

@if (TempData["AdminError"] is string adminError)
{
    <section class="panel form-panel validation">@adminError</section>
}

<section class="details-grid">
    <article class="panel">
        <h2>Users</h2>
        <table class="table compact">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Display name</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Role controls</th>
                    <th>Account actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.DisplayName</td>
                    <td>@user.Department</td>
                    <td>
                        @if (user.HasAssignedRole)
                        {
                            <span class="status approved">Active</span>
                        }
                        else
                        {
                            <span class="status submitted">Pending admin assignment</span>
                        }
                    </td>
                    <td>
                        @if (isPhoneClient)
                        {
                            <span class="small-note">Role assignment is unavailable on iPhone. Use iPad or Windows.</span>
                        }
                        else
                        {
                            <form asp-action="UpdateRoles" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <label class="checkbox-row"><input type="checkbox" name="isAdmin" value="true" @(user.IsAdmin ? "checked" : null) /> Admin</label>
                                <label class="checkbox-row"><input type="checkbox" name="isResearcher" value="true" @(user.IsResearcher ? "checked" : null) /> Researcher</label>
                                <label class="checkbox-row"><input type="checkbox" name="isReviewer" value="true" @(user.IsReviewer ? "checked" : null) /> Reviewer</label>
                                <button type="submit" class="button secondary">Save roles</button>
                            </form>
                        }
                    </td>
                    <td>
                        @if (isPhoneClient)
                        {
                            <span class="small-note">Account actions are unavailable on iPhone. Use iPad or Windows.</span>
                        }
                        else
                        {
                            <div class="stack-actions">
                                <form asp-action="SendPasswordResetEmail" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="button secondary">Send reset email</button>
                                </form>
                                @if (user.CanDelete)
                                {
                                    <form asp-action="DeleteUser" method="post" class="inline-form" onsubmit="return confirm('Delete this account? This cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="button danger">Delete account</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="small-note">Admin accounts cannot be deleted.</span>
                                }
                            </div>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </article>
    <article class="panel">
        <h2>Record templates</h2>
        <p class="small-note">Windows users can manage shared templates from the Templates area.</p>
        <ul class="entity-list">
            @foreach (var template in Model.Templates)
            {
                <li>
                    <span>@template.Name</span>
                    <span>@template.Description</span>
                </li>
            }
        </ul>
    </article>
</section>
