@model StorageLocationEditorViewModel
@{
    ViewData["Title"] = "Storage location details";
    bool isPhoneClient = ClientDeviceDetector.IsPhoneClient(Context.Request);
}

<section class="page-header split">
    <div>
        <p class="eyebrow">Storage Location</p>
        <h1>@Model.Name</h1>
        <p>@Model.Code</p>
    </div>
    <div class="button-group">
        <a class="button secondary" asp-action="Index">Back to locations</a>
        @if (User.IsInRole("Admin") && !isPhoneClient)
        {
            <a class="button primary" asp-action="Edit" asp-route-id="@Model.Id">Edit location</a>
        }
    </div>
</section>

<section class="details-grid">
    <article class="panel">
        <h2>Storage profile</h2>
        <dl class="definition-list">
            <div><dt>Code</dt><dd>@Model.Code</dd></div>
            <div><dt>Name</dt><dd>@Model.Name</dd></div>
            <div><dt>Notes</dt><dd>@Model.Notes</dd></div>
        </dl>
        <h3>Inventory items in this location</h3>
        <ul class="entity-list">
            @if (Model.InventoryItems.Count == 0)
            {
                <li>
                    <span>No inventory items are currently linked to this storage location.</span>
                    <span></span>
                    <span></span>
                </li>
            }
            else
            {
                @foreach (var item in Model.InventoryItems)
                {
                    <li>
                        <span>[ @item.ItemType ] @item.Code</span>
                        <span>@item.Name</span>
                        <a asp-controller="Inventory" asp-action="Details" asp-route-id="@item.Id">Open item</a>
                    </li>
                }
            }
        </ul>
        @if (User.IsInRole("Admin") && !isPhoneClient)
        {
            <section class="panel form-panel">
                <div class="panel-header"><h3>Add inventory items</h3></div>
                <form asp-action="AddInventoryItems" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label for="selectedInventoryItemIds">Inventory items</label>
                    <select id="selectedInventoryItemIds" name="selectedInventoryItemIds" multiple size="10">
                        @foreach (var option in Model.AvailableInventoryOptions)
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    </select>
                    <div class="editor-actions">
                        <button type="submit" class="button primary">Add to this storage location</button>
                    </div>
                </form>
            </section>
        }
    </article>
    <article class="panel">
        <h2>QR identity</h2>
        <div class="qr-card">@Html.Raw(Model.QrCodeSvg)</div>
        <label>QR payload</label>
        <textarea rows="4" readonly>@Model.QrCodeToken</textarea>
        @if (User.IsInRole("Admin") && !isPhoneClient)
        {
            <section class="panel form-panel">
                <div class="panel-header"><h3>Delete storage location</h3></div>
                <p class="small-note">Choose where the linked inventory items should move before this storage location is deleted.</p>
                <form asp-action="Delete" method="post" onsubmit="return confirm('Delete this storage location and move its inventory items?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <label for="replacementStorageLocationId">New storage location for linked inventory items</label>
                    <select id="replacementStorageLocationId" name="replacementStorageLocationId">
                        <option value="">Select a replacement location</option>
                        @foreach (var option in Model.ReplacementLocationOptions)
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    </select>
                    <div class="editor-actions">
                        <button type="submit" class="button ghost danger">Delete storage location</button>
                    </div>
                </form>
            </section>
        }
    </article>
</section>
