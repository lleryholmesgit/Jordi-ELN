@model ForgotPasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot password";
}

<section class="auth-shell">
    <div class="auth-card">
        <p class="eyebrow">Jordi ELN</p>
        <h1>Reset password with recovery answer</h1>
        <p>Enter your registered email address, answer your recovery question, and set a new password.</p>
        <form asp-action="ForgotPassword" method="post" data-recovery-question-form>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation"></div>
            <label asp-for="Email"></label>
            <input asp-for="Email" data-recovery-email />
            <label asp-for="RecoveryQuestion"></label>
            <input asp-for="RecoveryQuestion" readonly data-recovery-question />
            <label asp-for="RecoveryAnswer"></label>
            <input asp-for="RecoveryAnswer" />
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" />
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" />
            <button type="submit" class="button primary wide">Reset password</button>
        </form>
        <p class="small-note auth-footer-note">
            If you do not remember the recovery answer, ask an admin to send a reset email.
        </p>
        <p class="small-note auth-footer-note">
            <a asp-action="Login">Back to sign in</a>
        </p>
    </div>
</section>

<script>
(() => {
    const form = document.querySelector('[data-recovery-question-form]');
    if (!form) return;

    const emailInput = form.querySelector('[data-recovery-email]');
    const questionInput = form.querySelector('[data-recovery-question]');
    if (!emailInput || !questionInput) return;

    let lastEmail = '';

    async function loadQuestion() {
        const email = emailInput.value.trim();
        if (!email || email === lastEmail) return;
        lastEmail = email;

        try {
            const response = await fetch(`@Url.Action("RecoveryQuestion", "Account")?email=${encodeURIComponent(email)}`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            if (!response.ok) return;
            const payload = await response.json();
            questionInput.value = payload.question || '';
        } catch {
        }
    }

    emailInput.addEventListener('change', loadQuestion);
    emailInput.addEventListener('blur', loadQuestion);

    if (emailInput.value.trim()) {
        loadQuestion();
    }
})();
</script>
