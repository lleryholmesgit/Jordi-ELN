@model RegisterViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <div class="auth-card">
        <p class="eyebrow">Jordi ELN</p>
        <h1>Register</h1>
        <p>Create a lab account request. Access is granted only after an admin assigns your role.</p>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation"></div>
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <label asp-for="DisplayName"></label>
            <input asp-for="DisplayName" />
            <label asp-for="Department"></label>
            <input asp-for="Department" />
            <label asp-for="RecoveryQuestion"></label>
            <input asp-for="RecoveryQuestion" />
            <label asp-for="RecoveryAnswer"></label>
            <input asp-for="RecoveryAnswer" />
            <label asp-for="Password"></label>
            <input asp-for="Password" />
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" />
            <button type="submit" class="button primary wide">Register account</button>
        </form>
        <p class="small-note auth-footer-note">
            Already registered?
            <a asp-action="Login">Back to sign in</a>
        </p>
    </div>
</section>
