@model ResetPasswordViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Reset password";
}

<section class="auth-shell">
    <div class="auth-card">
        <p class="eyebrow">Jordi ELN</p>
        <h1>Reset password</h1>
        <p>Enter a new password for your account.</p>
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="validation"></div>
            <input asp-for="Email" type="hidden" />
            <input asp-for="Token" type="hidden" />
            <label asp-for="Email"></label>
            <input asp-for="Email" readonly />
            <label asp-for="NewPassword"></label>
            <input asp-for="NewPassword" />
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" />
            <button type="submit" class="button primary wide">Set new password</button>
        </form>
        <p class="small-note auth-footer-note">
            <a asp-action="Login">Back to sign in</a>
        </p>
    </div>
</section>
