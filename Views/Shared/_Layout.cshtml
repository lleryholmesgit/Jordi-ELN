<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jordi ELN</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <a class="brand" asp-controller="Inventory" asp-action="Index">Jordi ELN</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="nav-list">
                    <a asp-controller="Records" asp-action="Index">Records</a>
                    <a asp-controller="Inventory" asp-action="Index">Inventory</a>
                    <a asp-controller="StorageLocations" asp-action="Index">Storage Locations</a>
                    <a asp-controller="Templates" asp-action="Index">Templates</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index">Admin</a>
                    }
                </nav>
                <div class="sidebar-footer">
                    <div class="user-chip">
                        <span class="label">Signed in</span>
                        <strong>@User.Identity?.Name</strong>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button ghost">Sign out</button>
                    </form>
                </div>
            }
        </aside>
        <main class="content">
            @if (ClientDeviceDetector.IsPhoneClient(Context.Request))
            {
                <section class="panel form-panel ios-readonly-banner">
                    <strong>iPhone limited mode</strong>
                    <span>Browsing and scan workflows are supported on iPhone. Use iPad or Windows for full editing and administrative actions.</span>
                </section>
            }
            @RenderBody()
        </main>
    </div>
    <script src="~/js/record-editor.js" asp-append-version="true"></script>
    <script src="~/js/inventory-layout.js" asp-append-version="true"></script>
    <script src="~/js/qr-scan.js" asp-append-version="true"></script>
    <script src="~/js/template-editor.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
